// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User model for authentication
model User {
  id            String   @id @default(cuid())
  email         String   @unique
  passwordHash  String
  name          String?
  createdAt     DateTime @default(now())

  weeks         Week[]

  @@map("users")
}

// Week model - represents a weekly report
model Week {
  id              String   @id @default(cuid())
  weekNumber      Int
  year            Int
  startDate       DateTime
  endDate         DateTime
  reportFileUrl   String?
  status          Status   @default(DRAFT)
  createdById     String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  createdBy       User               @relation(fields: [createdById], references: [id])
  tasks           Task[]             // DEPRECATED
  taskProgress    WeekTaskProgress[] // NEW
  metricValues    WeekMetricValue[]  // NEW - Số liệu định lượng

  @@unique([weekNumber, year])
  @@index([createdById])
  @@map("weeks")
}

// Department model - represents departments/phòng ban
model Department {
  id          String    @id @default(cuid())
  name        String    @unique
  description String?
  createdAt   DateTime  @default(now())
  deletedAt   DateTime?

  masterTasks            MasterTask[]
  tasks                  Task[]
  metricDefinitions      MetricDefinition[]
  secretaries            Secretary[]
  transfersFrom          SecretaryTransferLog[] @relation("TransferFrom")
  transfersTo            SecretaryTransferLog[] @relation("TransferTo")
  secretaryApplications  SecretaryApplication[] @relation("ApplicationDesiredDept")

  @@map("departments")
}

// MasterTask - Danh sách nhiệm vụ chung của mỗi phòng
model MasterTask {
  id                String    @id @default(cuid())
  departmentId      String
  name              String    @db.Text
  description       String?   @db.Text
  estimatedDuration Int?      // Số tuần dự kiến hoàn thành (DEPRECATED - dùng startDate/endDate)
  startDate         DateTime? // Ngày bắt đầu nhiệm vụ
  endDate           DateTime? // Ngày kết thúc nhiệm vụ
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  department        Department         @relation(fields: [departmentId], references: [id])
  weekProgress      WeekTaskProgress[]

  @@index([departmentId])
  @@map("master_tasks")
}

// WeekTaskProgress - Tiến độ nhiệm vụ từng tuần
model WeekTaskProgress {
  id             String    @id @default(cuid())
  masterTaskId   String
  weekId         String
  orderNumber    Int       // Thứ tự hiển thị trong tuần
  result         String    @db.Text // Kết quả tuần này
  timePeriod     String    // Thời gian thực hiện
  progress       Int?      // 0-100, null nếu nhiệm vụ không có tiến độ
  nextWeekPlan   String    @db.Text
  isImportant    Boolean   @default(false)
  completedAt    DateTime? // Ngày hoàn thành (nếu progress = 100)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  masterTask     MasterTask @relation(fields: [masterTaskId], references: [id], onDelete: Cascade)
  week           Week       @relation(fields: [weekId], references: [id], onDelete: Cascade)

  @@unique([masterTaskId, weekId]) // Mỗi nhiệm vụ chỉ xuất hiện 1 lần/tuần
  @@index([weekId])
  @@index([masterTaskId])
  @@map("week_task_progress")
}

// Task model - DEPRECATED - giữ lại để backward compatible
// Sẽ migrate dần sang WeekTaskProgress
model Task {
  id             String   @id @default(cuid())
  weekId         String
  departmentId   String
  orderNumber    Int
  taskName       String   @db.Text
  result         String   @db.Text
  timePeriod     String
  progress       Int?     // 0-100, null nếu nhiệm vụ không có tiến độ
  nextWeekPlan   String   @db.Text
  isImportant    Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  week           Week       @relation(fields: [weekId], references: [id], onDelete: Cascade)
  department     Department @relation(fields: [departmentId], references: [id])

  @@index([weekId])
  @@index([departmentId])
  @@map("tasks")
}

// MetricDefinition - Định nghĩa các chỉ số của phòng ban
model MetricDefinition {
  id           String   @id @default(cuid())
  departmentId String
  name         String   @db.Text // Tên chỉ số (VD: "Số ca ghép tim", "Nghiên cứu khoa học")
  unit         String?  // Đơn vị (VD: "ca", "bài", "nghiên cứu")
  description  String?  @db.Text
  orderNumber  Int      @default(0) // Thứ tự hiển thị
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  department   Department        @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  weekValues   WeekMetricValue[]

  @@index([departmentId])
  @@map("metric_definitions")
}

// WeekMetricValue - Giá trị số liệu theo tuần
model WeekMetricValue {
  id               String   @id @default(cuid())
  metricId         String
  weekId           String
  value            Float    // Giá trị số liệu
  note             String?  @db.Text // Ghi chú (nếu có)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  metric           MetricDefinition @relation(fields: [metricId], references: [id], onDelete: Cascade)
  week             Week             @relation(fields: [weekId], references: [id], onDelete: Cascade)

  @@unique([metricId, weekId]) // Mỗi chỉ số chỉ có 1 giá trị/tuần
  @@index([weekId])
  @@index([metricId])
  @@map("week_metric_values")
}

// Event - Lịch làm việc
model Event {
  id              String         @id @default(cuid())
  date            DateTime       // Ngày diễn ra
  time            String?        // Giờ diễn ra (VD: "13g30", "08g00")
  location        String?        @db.Text // Địa điểm
  content         String         @db.Text // Nội dung sự kiện
  chair           String?        @db.Text // Người chủ trì
  participants    String?        @db.Text // Đơn vị chuẩn bị/tham dự
  note            String?        @db.Text // Ghi chú
  status          EventStatus    @default(UNCONFIRMED) // Trạng thái xác nhận
  isEdited        Boolean        @default(false) // Đã chỉnh sửa sau khi tạo
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([date])
  @@map("events")
}

enum Status {
  DRAFT
  COMPLETED
}

enum EventStatus {
  CONFIRMED     // Đã xác nhận
  UNCONFIRMED   // Chưa xác nhận
}

// Meeting Room - Phòng họp
model MeetingRoom {
  id              String    @id @default(cuid())
  name            String    @unique
  location        String?   @db.Text
  capacity        Int
  description     String?   @db.Text

  // Thiết bị âm thanh
  hasMicrophone   Boolean   @default(false)
  hasSpeaker      Boolean   @default(false)
  audioSystemType String?   @db.Text

  // Thiết bị hình ảnh
  hasProjector    Boolean   @default(false)
  hasScreen       Boolean   @default(false)
  hasTV           Boolean   @default(false)
  hasSmartBoard   Boolean   @default(false)
  visualEquipment String?   @db.Text

  // Tiện ích khác
  hasWifi         Boolean   @default(false)
  hasAircon       Boolean   @default(false)
  hasWhiteboard   Boolean   @default(false)
  furnitureType   String?   @db.Text
  otherAmenities  String?   @db.Text

  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  hospitalEvents  HospitalEvent[]

  @@map("meeting_rooms")
}

// Hospital Event - Sự kiện bệnh viện
model HospitalEvent {
  id              String            @id @default(cuid())
  name            String            @db.Text
  date            DateTime
  time            String?
  description     String?           @db.Text

  meetingRoomId   String?
  meetingRoom     MeetingRoom?      @relation(fields: [meetingRoomId], references: [id])

  eventType       HospitalEventType @default(ORGANIZED)

  chair           String?           @db.Text
  participants    String?           @db.Text
  note            String?           @db.Text

  status          EventStatus       @default(UNCONFIRMED)
  isEdited        Boolean           @default(false)

  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  deletedAt       DateTime?

  checklistItems  EventChecklistItem[]

  @@index([date])
  @@index([meetingRoomId])
  @@map("hospital_events")
}

// Checklist Template - Master checklist
model ChecklistTemplate {
  id          String    @id @default(cuid())
  title       String    @db.Text
  description String?   @db.Text
  orderNumber Int       @default(0)
  isDefault   Boolean   @default(true)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("checklist_templates")
}

// Event Checklist Item - Instance per event
model EventChecklistItem {
  id              String        @id @default(cuid())
  hospitalEventId String
  hospitalEvent   HospitalEvent @relation(fields: [hospitalEventId], references: [id], onDelete: Cascade)

  title           String        @db.Text
  description     String?       @db.Text
  orderNumber     Int           @default(0)
  isCompleted     Boolean       @default(false)
  completedAt     DateTime?

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([hospitalEventId])
  @@map("event_checklist_items")
}

enum HospitalEventType {
  ORGANIZED     // Tổ chức
  COLLABORATED  // Phối hợp
}

// ==================== SECRETARY MANAGEMENT ====================

// SecretaryType - Loại thư ký
model SecretaryType {
  id          String    @id @default(cuid())
  name        String    @unique // VD: "Thư ký y khoa", "Thư ký hành chính"
  description String?   @db.Text
  color       String?   // Màu hiển thị (hex code)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  secretaries  Secretary[]
  applications SecretaryApplication[]

  @@map("secretary_types")
}

// Secretary - Thư ký
model Secretary {
  id                  String          @id @default(cuid())
  fullName            String          // Họ và tên
  dateOfBirth         DateTime?       // Ngày sinh
  phone               String?
  email               String?
  avatar              String?         // URL ảnh đại diện

  secretaryTypeId     String?
  secretaryType       SecretaryType?  @relation(fields: [secretaryTypeId], references: [id])

  currentDepartmentId String?
  currentDepartment   Department?     @relation(fields: [currentDepartmentId], references: [id])

  status              SecretaryStatus @default(ACTIVE)
  startDate           DateTime?       // Ngày bắt đầu làm thư ký
  notes               String?         @db.Text

  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  deletedAt           DateTime?

  certificates        SecretaryCertificate[]
  transferLogs        SecretaryTransferLog[]
  application         SecretaryApplication?

  @@index([secretaryTypeId])
  @@index([currentDepartmentId])
  @@index([dateOfBirth])
  @@map("secretaries")
}

// SecretaryCertificate - Bằng cấp của thư ký
model SecretaryCertificate {
  id            String    @id @default(cuid())
  secretaryId   String
  secretary     Secretary @relation(fields: [secretaryId], references: [id], onDelete: Cascade)

  name          String    // Tên bằng cấp
  issuedYear    Int?      // Năm cấp bằng
  issuedBy      String?   // Nơi cấp
  attachmentUrl String?   // File đính kèm (scan bằng)
  notes         String?   @db.Text

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([secretaryId])
  @@map("secretary_certificates")
}

// SecretaryTransferLog - Lịch sử luân chuyển
model SecretaryTransferLog {
  id               String     @id @default(cuid())
  secretaryId      String
  secretary        Secretary  @relation(fields: [secretaryId], references: [id], onDelete: Cascade)

  fromDepartmentId String?
  fromDepartment   Department? @relation("TransferFrom", fields: [fromDepartmentId], references: [id])

  toDepartmentId   String
  toDepartment     Department  @relation("TransferTo", fields: [toDepartmentId], references: [id])

  transferDate     DateTime    // Ngày luân chuyển
  decisionNumber   String?     // Số quyết định
  reason           String?     @db.Text // Lý do luân chuyển
  notes            String?     @db.Text

  createdAt        DateTime    @default(now())
  createdBy        String?     // User ID tạo record

  @@index([secretaryId])
  @@index([fromDepartmentId])
  @@index([toDepartmentId])
  @@index([transferDate])
  @@map("secretary_transfer_logs")
}

enum SecretaryStatus {
  ACTIVE      // Đang hoạt động
  INACTIVE    // Nghỉ việc
  ON_LEAVE    // Đang nghỉ phép dài hạn
}

enum ApplicationStatus {
  SCREENING   // Vòng 1 - Sơ tuyển
  INTERVIEW   // Vòng 2 - Phỏng vấn
  ACCEPTED    // Đã nhận việc
  REJECTED    // Từ chối
}

// SecretaryApplication - Hồ sơ ứng tuyển thư ký
model SecretaryApplication {
  id                   String            @id @default(cuid())
  fullName             String
  dateOfBirth          DateTime?
  phone                String?
  email                String?
  cvUrl                String?           // Link/URL CV đính kèm

  appliedTypeId        String?           // Loại thư ký ứng tuyển
  appliedType          SecretaryType?    @relation(fields: [appliedTypeId], references: [id])

  desiredDepartmentId  String?           // Phòng ban mong muốn
  desiredDepartment    Department?       @relation("ApplicationDesiredDept", fields: [desiredDepartmentId], references: [id])

  source               String?           // Nguồn tuyển dụng (LinkedIn, giới thiệu nội bộ, website...)

  status               ApplicationStatus @default(SCREENING)

  // Vòng phỏng vấn
  interviewDate        DateTime?
  interviewScore       Float?
  interviewNotes       String?           @db.Text

  notes                String?           @db.Text

  // Khi được nhận việc → liên kết với Secretary được tạo
  convertedSecretaryId String?           @unique
  convertedSecretary   Secretary?        @relation(fields: [convertedSecretaryId], references: [id])

  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  deletedAt            DateTime?

  @@index([status])
  @@index([appliedTypeId])
  @@index([desiredDepartmentId])
  @@map("secretary_applications")
}
