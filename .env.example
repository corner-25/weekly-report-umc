# Database
DATABASE_URL="postgresql://user:password@localhost:5432/report_db?schema=public"
# Read-only role for the AI chatbot (SELECT only, statement_timeout 5s)
DATABASE_URL_RO="postgresql://chatbot_readonly:CHANGE_ME@localhost:5432/report_db?schema=public"

# AI Chatbot
DEEPSEEK_API_KEY="sk-..."
CHATBOT_MAX_TOKENS_PER_REQUEST="1500"
CHATBOT_RATE_LIMIT_PER_HOUR="20"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-change-this-in-production"

# File Upload
UPLOAD_DIR="./public/uploads"

# Embedded Python dashboards (Streamlit) - đặt URL production trên Railway Variables
# Mỗi dashboard deploy riêng trên Railway, lấy URL từ Railway dashboard
DASHBOARD_PHONG_HC_URL="https://your-phong-hc.railway.app"
DASHBOARD_PHONG_HC_OLD_URL="https://your-phong-hc-old.railway.app"
DASHBOARD_TO_XE_URL="https://your-to-xe.railway.app"
DASHBOARD_UMC_URL="https://your-umc.railway.app"
